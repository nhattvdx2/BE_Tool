APP_HOST=127.0.0.1
APP_PORT=8000
ADMIN_PORT=8080
SERVE_ADMIN_UI=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/be_tool?connect_timeout=5
CORS_ORIGINS=http://localhost:4200
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=uploads
DEFAULT_CLONE_VOICE_LIMIT=0
DEFAULT_DESIGN_VOICE_LIMIT=0
MAX_AUDIO_FILE_SIZE_MB=20
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=logs/audit
AUDIT_LOG_MAX_BYTES=10485760
AUDIT_LOG_BACKUP_COUNT=5
